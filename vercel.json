{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "ignoreCommand": "[ ! -d .git ] || git diff --quiet HEAD~1 HEAD --",
  "nodejs": "20.x",
  "rewrites": [
    {
      "source": "/:path((?!_next/static/|_next/image/|favicon.ico).*)",
      "destination": "/"
    }
  ]
}
